{
  "name": "repolens",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered GitHub repository architecture insight tool.",
  "license": "MIT",
  "packageManager": "pnpm@10.6.1",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build:ts": "tsc -p tsconfig.json",
    "build:web": "vite build --config web/vite.config.ts",
    "build": "pnpm build:ts && pnpm build:web",
    "dev": "concurrently \"tsx watch server/src/index.ts\" \"vite --config web/vite.config.ts\"",
    "start": "node dist/server/src/index.js",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run",
    "prepare": "husky"
  },
  "dependencies": {
    "axios": "^1.8.4",
    "express": "^4.21.2",
    "fast-glob": "^3.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-flow-renderer": "^10.3.17",
    "simple-git": "^3.27.0",
    "ts-morph": "^25.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^9.1.7",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.1",
    "vitest": "^3.0.8"
  }
}