{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": "."
  },
  "include": [
    "cli/**/*.ts",
    "parser/**/*.ts",
    "ai/**/*.ts",
    "graph/**/*.ts",
    "server/**/*.ts",
    "tests/**/*.ts",
    "scripts/**/*.ts"
  ]
}